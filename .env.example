# GPO Analyzer - Environment Variables
# Copy this file to .env and fill in your values.

# ============================================================================
# Authentication (Entra ID / Azure AD) - Optional
# ============================================================================
# Register an app in Azure Portal > App Registrations
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AUTH_ENABLED=false

# ============================================================================
# Data Paths (Docker) - defaults work for standard deployment
# ============================================================================
# GPO_HTML_FOLDER=/app/data/html_reports
# GPO_DOWNLOAD_FOLDER=/app/data/downloads
# GPO_AUDIT_LOG_FILE=/app/data/audit.log

# ============================================================================
# Container Registry (Production deployment only)
# ============================================================================
# REGISTRY=your-registry.azurecr.io
# TAG=latest
