# GPO Analyzer Web - Environment Variables
# Copy this file to .env and adjust values as needed

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================

# Port to expose the application (default: 80)
GPO_PORT=80

# =============================================================================
# BACKEND SETTINGS  
# =============================================================================

# Path to GPOZaurr HTML reports folder (inside container)
GPO_HTML_FOLDER=/app/data/html_reports

# Path for user-uploaded files (inside container)
GPO_UPLOAD_FOLDER=/app/data/uploads

# CORS allowed origins (JSON array format)
# Add your domain if deploying behind a reverse proxy
GPO_CORS_ORIGINS=["http://localhost","http://localhost:3000"]

# Cache TTL in seconds (how long to cache parsed data)
GPO_CACHE_TTL=300

# Pagination settings
GPO_DEFAULT_PAGE_SIZE=50
GPO_MAX_PAGE_SIZE=100

# =============================================================================
# FRONTEND SETTINGS
# =============================================================================

# Backend API URL (set during build, leave empty for relative URLs)
VITE_API_URL=

# =============================================================================
# LOGGING (optional)
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
# GPO_LOG_LEVEL=INFO
